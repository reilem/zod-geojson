{
    "compilerOptions": {
        "target": "es2019",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": ["esnext", "dom"],
        "types": ["node"],
        "rootDir": ".",
        "noEmit": true,
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "isolatedModules": true,
        "noErrorTruncation": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules", "lib"]
}
